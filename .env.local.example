# Copy to .env.local for local dev, or add these in Vercel → Project → Settings → Environment Variables

# Contact form uses the custom QuoteForm UI and /api/contact on our Cloudflare Worker.
# Email is sent with Cloudflare Email Service (3,000 emails/month on Workers Paid).
# One-time setup in Cloudflare Dashboard:
#   Email > Email Sending > enable a1pslandscape.com
# Or run: npx wrangler email sending enable a1pslandscape.com

# Google Analytics 4 measurement ID (optional, e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Google Maps API key (optional: contact page uses a static embed without one)
NEXT_PUBLIC_MAPS_KEY=

# Search engine verification (optional: from Google Search Console / Bing Webmaster Tools)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# IndexNow: notifies Bing, Yandex, and other IndexNow engines when URLs change.
# Generate: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
# Also set on Cloudflare: npx wrangler secret put INDEXNOW_KEY
# Build writes public/{INDEXNOW_KEY}.txt so IndexNow can verify ownership.
INDEXNOW_KEY=

# Bearer token for POST /api/reindex. Set on Cloudflare: npx wrangler secret put REINDEX_WEBHOOK_SECRET
# npm run deploy runs indexnow:submit automatically after wrangler deploy.
REINDEX_WEBHOOK_SECRET=

# Google Places API Key: enables LIVE review count from Google
# Get a key at https://console.cloud.google.com/apis/credentials
# Enable "Places API (New)" in your GCP project: free tier covers this usage
# GOOGLE_PLACES_API_KEY=
