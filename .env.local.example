# Copy to .env.local for local dev, or add these in Vercel → Project → Settings → Environment Variables

# Contact form sends to siteConfig.email via FormSubmit (no API keys required).
# After deploy, submit the form once and click the activation link sent to that inbox.

# Google Analytics 4 measurement ID (optional, e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Microsoft Clarity project ID (optional: heatmaps, session recordings)
NEXT_PUBLIC_CLARITY_ID=

# Google Maps API key (optional: contact page uses a static embed without one)
NEXT_PUBLIC_MAPS_KEY=

# Search engine verification (optional: from Google Search Console / Bing Webmaster Tools)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# IndexNow: notifies Bing, Yandex, and other IndexNow engines when URLs change
# Generate a random 32-char hex string, e.g. openssl rand -hex 16
INDEXNOW_KEY=

# Secret for POST /api/reindex (use in a Vercel Deploy Hook or after manual deploys)
REINDEX_WEBHOOK_SECRET=

# Google Places API Key: enables LIVE review count from Google
# Get a key at https://console.cloud.google.com/apis/credentials
# Enable "Places API (New)" in your GCP project: free tier covers this usage
# GOOGLE_PLACES_API_KEY=
